# ========================================
# Backend Server Configuration
# ========================================

PORT=3001

# ========================================
# Requirements Analysis Configuration
# ========================================

# Supported values:
# mock - Returns the deterministic development process model
# ai   - Sends requirements to the centrally configured AI provider
ANALYSIS_MODE=ai

# Currently implemented provider:
# openai
AI_PROVIDER=openai

# ========================================
# OpenAI Provider Configuration
# ========================================

# Store the real API key only in backend/.env or a production secrets manager.
# Never commit the key or expose it through frontend environment variables.
OPENAI_API_KEY=replace-with-openai-api-key

# Use a model available to the OpenAI API project.
OPENAI_MODEL=replace-with-approved-model

# Maximum amount of generated output available for the process-model JSON.
OPENAI_MAX_OUTPUT_TOKENS=6000